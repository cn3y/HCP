# Server Configuration
PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Database Configuration
# Set DB_TYPE=postgres for PostgreSQL, default is SQLite
DB_TYPE=sqlite

# SQLite (default)
DB_PATH=./data/golf-handicap.db

# PostgreSQL (optional)
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=golf
# PG_PASSWORD=golf
# PG_DATABASE=golf_handicap
